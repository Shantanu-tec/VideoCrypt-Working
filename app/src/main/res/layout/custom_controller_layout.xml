<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <ImageView
        android:id="@+id/backBtn"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:focusable="true"
        android:nextFocusLeft="@id/rewindIv"
        android:nextFocusUp="@id/rewindIv"
        android:nextFocusDown="@id/exo_progress"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:scaleX="0.5"
        android:scaleY="0.5"
        android:src="@drawable/outline_arrow_left_alt_24" />


    <ImageView
        android:id="@+id/quality"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"
        android:focusable="true"
        android:nextFocusLeft="@id/rewindIv"
        android:nextFocusUp="@id/rewindIv"
        android:nextFocusDown="@id/exo_progress"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:scaleX="0.5"
        android:scaleY="0.5"
        android:src="@mipmap/settings" />




    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        >

        <ImageView
            android:id="@+id/rewindIv"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:focusable="true"
            android:nextFocusLeft="@id/rewindIv"
            android:nextFocusUp="@id/rewindIv"
            android:nextFocusDown="@id/exo_progress"
            android:scaleX="0.5"
            android:scaleY="0.5"
            android:src="@mipmap/backward" />

        <LinearLayout
            android:id="@+id/playPauseRl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp12"
            android:layout_toEndOf="@id/rewindIv"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/playIv"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:focusable="true"
                android:nextFocusLeft="@id/rewindIv"
                android:nextFocusRight="@id/fastForwardIv"
                android:nextFocusUp="@id/playIv"
                android:nextFocusDown="@id/exo_progress"
                android:scaleX="0.5"
                android:scaleY="0.5"
                android:src="@mipmap/play"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/pauseIv"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:focusable="true"
                android:nextFocusLeft="@id/rewindIv"
                android:nextFocusRight="@id/fastForwardIv"
                android:nextFocusUp="@id/pauseIv"
                android:nextFocusDown="@id/exo_progress"
                android:scaleX="0.5"
                android:scaleY="0.5"
                android:src="@mipmap/pause"
                android:visibility="visible" />
        </LinearLayout>

        <ImageView
            android:id="@+id/fastForwardIv"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginStart="@dimen/dp12"
            android:layout_toEndOf="@id/playPauseRl"
            android:focusable="true"
            android:scaleX="0.5"
            android:scaleY="0.5"
            android:src="@mipmap/forward" />
    </RelativeLayout>


    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/goLiveRl"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="15dp"
        android:visibility="gone"
        tools:visibility="visible"
        android:padding="8dp"
        android:background="@drawable/item_background_golive"
        app:layout_constraintBottom_toTopOf="@id/seekbarLayout">

        <ImageView
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:src="@mipmap/red_dot"
            android:layout_centerVertical="true"
            android:id="@+id/redDot"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Go Live"
            android:layout_toEndOf="@id/redDot"
            android:layout_marginStart="@dimen/dp5"
            android:textColor="#F40303"
            android:textStyle="bold"
            android:textSize="15sp"/>

    </RelativeLayout>


    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="15dp"
        android:id="@+id/seekbarLayout"
        app:layout_constraintEnd_toStartOf="@id/orientation"
        app:layout_constraintBottom_toBottomOf="parent">



        <TextView
            android:id="@+id/exo_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white" />

        <androidx.media3.ui.DefaultTimeBar
            android:id="@+id/exo_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/exo_position"
            android:layout_toStartOf="@id/exo_duration"
            android:focusable="true"
            android:visibility="visible"
            app:buffered_color="#95989F"
            app:played_color="#D50000"
            app:unplayed_color="#45424E" />

        <TextView
            android:id="@+id/exo_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:textColor="@android:color/white" />

    </RelativeLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/black"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/quality"
        android:id="@+id/recyclerViewQuality"/>


    <ImageView
        android:id="@+id/orientation"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:scaleX="0.5"
        android:scaleY="0.5"
        android:src="@mipmap/fullscreen" />






</androidx.constraintlayout.widget.ConstraintLayout>